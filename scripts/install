#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# INITIALIZE AND STORE SETTINGS
#=================================================
ynh_script_progression --message="Storing installation settings..." --weight=1

# Generate secure random keys
hash_key=$(ynh_string_random --length=64)
block_key=$(ynh_string_random --length=32)
shared_secret=$(ynh_string_random --length=64)

# Store settings
ynh_app_setting_set --key=hash_key --value="$hash_key"
ynh_app_setting_set --key=block_key --value="$block_key"
ynh_app_setting_set --key=shared_secret --value="$shared_secret"

# Backend password generation
while IFS= read -r backend_url; do
    if [[ -n "$backend_url" ]]; then
        backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
        varname="pwd__${backend_id}"
        password=$(ynh_string_random --length=32)
        ynh_app_setting_set --key="$varname" --value="$password"
    fi
done <<< "$backends_urls"

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression --message="Setting up source files..." --weight=3

ynh_setup_source --dest_dir="$install_dir"
chown -R "$app:www-data" "$install_dir"

#=================================================
# BUILD APPLICATION
#=================================================
ynh_script_progression --message="Building Nextcloud signaling server..." --weight=10

# Install Go
ynh_go_install

# Set up Go environment
export PATH="/usr/local/go/bin:$PATH"
export GOPATH="$install_dir/go"
export GOCACHE="$install_dir/.cache/go-build"
export CGO_ENABLED=1

# Create necessary directories
mkdir -p "$GOPATH" "$GOCACHE"
chown -R "$app:www-data" "$GOPATH" "$GOCACHE"

# Build the application
pushd "$install_dir"
    ynh_exec_as_app env PATH="$PATH" GOPATH="$GOPATH" GOCACHE="$GOCACHE" make build
popd

# Clean up build artifacts but keep the binary
ynh_go_remove

# Ensure proper ownership
chown -R "$app:www-data" "$install_dir"
chmod +x "$install_dir/bin/signaling"

#=================================================
# APP INITIAL CONFIGURATION
#=================================================
ynh_script_progression --message="Adding configuration files..." --weight=2

# Create configuration directories
mkdir -p "/etc/$app" "/var/log/$app"

# Signaling server configuration
ynh_config_add --jinja --template="server.conf" --destination="/etc/$app/server.conf"
chmod 600 "/etc/$app/server.conf"
chown "$app:$app" "/etc/$app/server.conf"

# Janus configuration
mkdir -p /etc/janus
ynh_config_add --template="janus.jcfg" --destination="/etc/janus/janus.jcfg"
ynh_config_add --template="janus.transport.http.jcfg" --destination="/etc/janus/janus.transport.http.jcfg"
ynh_config_add --template="janus.transport.websockets.jcfg" --destination="/etc/janus/janus.transport.websockets.jcfg"
chmod 644 /etc/janus/*.jcfg

# NATS server configuration
ynh_config_add --template="nats-server.conf" --destination="/etc/nats-server.conf"
chmod 644 "/etc/nats-server.conf"
chown nats:nats "/etc/nats-server.conf"

# Log directory
chown -R "$app:$app" "/var/log/$app"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression --message="Adding system configurations..." --weight=3

# Add nginx configuration
ynh_config_add_nginx

# Add systemd service
ynh_config_add_systemd

# Add to YunoHost services
yunohost service add janus --description="Janus WebRTC server for Nextcloud Talk" --log="/var/log/janus/janus.log"
yunohost service add nats-server --description="NATS server for Nextcloud signaling" --log="/var/log/nats-server.log"
yunohost service add "$app" --description="Nextcloud signaling server" --log="/var/log/$app/$app.log"

# Add log rotation
ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICES
#=================================================
ynh_script_progression --message="Starting services..." --weight=3

# Ensure NATS server is running first
ynh_systemctl --service=nats-server --action=enable
ynh_systemctl --service=nats-server --action=restart --wait_until_running

# Then start Janus
ynh_systemctl --service=janus --action=enable
ynh_systemctl --service=janus --action=restart --wait_until_running

# Finally start the signaling server
ynh_systemctl --service="$app" --action=enable
ynh_systemctl --service="$app" --action=restart --wait_until_running

# Verify services are running
ynh_script_progression --message="Verifying services..." --weight=1

# Give services time to fully start
sleep 5

# Check if signaling server is responding
if ! curl -f -s http://127.0.0.1:$port/api/v1/welcome >/dev/null; then
    ynh_print_warn "Signaling server may not be responding properly. Check logs: journalctl -u $app"
fi

#=================================================
# END OF SCRIPT
#=================================================
ynh_script_progression --message="Installation of $app completed" --last
