#!/bin/bash

source /usr/share/yunohost/helpers

#=================================================
# LOAD SETTINGS
#=================================================

ynh_print_info "Declaring files to be backed up..."

#=================================================
# BACKUP THE APP MAIN DIR
#=================================================

# Only backup if install directory exists
if [[ -d "$install_dir" ]]; then
    ynh_backup "$install_dir"
else
    ynh_print_warn "Install directory $install_dir does not exist, skipping backup"
fi

#=================================================
# SYSTEM CONFIGURATION
#=================================================

ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"

# Backup the signaling config
if [[ -d "/etc/$app" ]]; then
    ynh_backup "/etc/$app/"
fi

# Backup janus config
if [[ -d "/etc/janus" ]]; then
    ynh_backup "/etc/janus/"
fi

# Backup nats-server config
if [[ -f "/etc/nats-server.conf" ]]; then
    ynh_backup "/etc/nats-server.conf"
fi

# Backup the systemd service unit
if [[ -f "/etc/systemd/system/$app.service" ]]; then
    ynh_backup "/etc/systemd/system/$app.service"
fi

# Backup the logrotate configuration
if [[ -f "/etc/logrotate.d/$app" ]]; then
    ynh_backup "/etc/logrotate.d/$app"
fi

#=================================================
# BACKUP LOG FILES
#=================================================

# Backup logs if directory exists
if [[ -d "/var/log/$app" ]]; then
    ynh_backup "/var/log/$app/"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will then actually copy those files to the archive)."
