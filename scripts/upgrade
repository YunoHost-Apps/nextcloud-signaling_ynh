#!/bin/bash

source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping systemd services..."

ynh_systemctl --service="$app" --action="stop"
ynh_systemctl --service="janus" --action="stop"
ynh_systemctl --service="nats-server" --action="stop"

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

ynh_setup_source --dest_dir="$install_dir" --full_replace --keep="server.conf"

#=================================================
# BUILD APPLICATION
#=================================================
ynh_script_progression "Building Nextcloud signaling server..."

#chmod u+x /etc/profile.d/goenv.sh
#/etc/profile.d/goenv.sh

# Set up Go environment
export PATH="/usr/local/go/bin:$PATH"
export GOPATH="$install_dir/go"
export GOCACHE="$install_dir/.cache/go-build"
export CGO_ENABLED=1

# Create necessary directories
mkdir -p "$GOPATH" "$GOCACHE"
chown -R "$app:www-data" "$GOPATH" "$GOCACHE"

# Build the application
pushd "$install_dir"
    ynh_hide_warnings ynh_exec_as_app GOPATH="$GOPATH" GOCACHE="$GOCACHE" make build
popd

# Clean up build artifacts but keep the binary
ynh_safe_rm "$install_dir/.cache/"
ynh_safe_rm "$install_dir/go/"
ynh_safe_rm "$install_dir/.go-version"

# Ensure proper ownership
chown -R "$app:www-data" "$install_dir"
chmod +x "$install_dir/bin/signaling"

# Restrict world access to install dir for security
chmod 750 "$install_dir"

#=================================================
# UPDATE A CONFIG FILE
#=================================================
ynh_script_progression "Updating configuration files..."

# Create configuration directories
mkdir -p "/var/log/$app"

# Export backend passwords as environment variables for Jinja template
while IFS= read -r backend_url; do
    if [[ -n "$backend_url" ]]; then
        backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
        varname="pwd__${backend_id}"
        password=$(ynh_app_setting_get --key="$varname")
        export "$varname"="$password"
    fi
done <<< "$(ynh_app_setting_get --key=backends_urls)"

# Export port variables for Jinja template
export port_janus_ws="$port_janus_ws"
export port_janus_http="$port_janus_http"
export port_nats="$port_nats"

# Export other variables for Jinja template
hash_key=$(ynh_app_setting_get --key=hash_key)
block_key=$(ynh_app_setting_get --key=block_key)
shared_secret=$(ynh_app_setting_get --key=shared_secret)
backends_urls=$(ynh_app_setting_get --key=backends_urls)
export hash_key="$hash_key"
export block_key="$block_key"
export shared_secret="$shared_secret"
export backends_urls="$backends_urls"
export turn_api_key="${turn_api_key:-}"
export turn_secret="${turn_secret:-}"
export turn_endpoints="${turn_endpoints:-}"

# Signaling server configuration
ynh_config_add --jinja --template="server.conf" --destination="$install_dir/server.conf"
chmod 600 "$install_dir/server.conf"

# Janus configuration
mkdir -p /etc/janus
ynh_config_add --template="janus.jcfg" --destination="/etc/janus/janus.jcfg"
ynh_config_add --template="janus.transport.http.jcfg" --destination="/etc/janus/janus.transport.http.jcfg"
ynh_config_add --template="janus.transport.websockets.jcfg" --destination="/etc/janus/janus.transport.websockets.jcfg"
chmod 644 /etc/janus/*.jcfg

# NATS server configuration
ynh_config_add --template="nats-server.conf" --destination="/etc/nats-server.conf"
chmod 644 "/etc/nats-server.conf"
chown nats:nats "/etc/nats-server.conf"

# Log directory
chown -R "$app:$app" "/var/log/$app"

#=================================================
# REAPPLY SYSTEM CONFIGURATIONS
#=================================================
ynh_script_progression "Upgrading system configurations..."

ynh_config_add_nginx

ynh_config_add_systemd

# Add to YunoHost services
yunohost service add janus --description="Janus WebRTC server for Nextcloud Talk" --log="/var/log/janus/janus.log"
yunohost service add nats-server --description="NATS server for Nextcloud signaling"
yunohost service add "$app" --description="Nextcloud signaling server" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting services..."

# Start services one by one with proper error checking
# Start NATS server first
ynh_script_progression "Starting NATS server..."

# Ensure NATS server is in clean state
ynh_systemctl --service=nats-server --action=stop || true
ynh_systemctl --service=nats-server --action=disable || true

# Start NATS server
ynh_systemctl --service=nats-server --action=enable
ynh_systemctl --service=nats-server --action=start

# Give NATS time to start and check status
sleep 5
if ! systemctl is-active --quiet nats-server; then
    ynh_print_info "NATS server status:"
    systemctl status nats-server --no-pager -l || true
    ynh_print_info "NATS server logs:"
    journalctl -u nats-server --no-pager -l --lines=20 || true
    ynh_die "Failed to start NATS server. Check logs above for details."
fi

# Wait a moment before starting next service
sleep 2

# Start Janus
ynh_script_progression "Starting Janus..."
ynh_systemctl --service=janus --action=enable
ynh_systemctl --service=janus --action=start
# Give Janus time to start and check status
sleep 5
if ! systemctl is-active --quiet janus; then
    ynh_die "Failed to start Janus"
fi

# Wait a moment before starting signaling server
sleep 2

# Start the signaling server
ynh_script_progression "Starting signaling server..."
ynh_systemctl --service="$app" --action=enable
ynh_systemctl --service="$app" --action=start
# Give signaling server time to start and check status
sleep 5
if ! systemctl is-active --quiet "$app"; then
    ynh_die "Failed to start signaling server. Check logs: journalctl -u $app"
fi

# Verify services are running
ynh_script_progression "Verifying services..."

# Give services time to fully start
sleep 5

# Check if all services are active
for service in nats-server janus "$app"; do
    if ! systemctl is-active --quiet "$service"; then
        ynh_print_warn "Service $service is not running. Check logs: journalctl -u $service"
    fi
done

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
