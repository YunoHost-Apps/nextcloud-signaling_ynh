#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

# Don't use ynh_abort_if_errors for config scripts as it can cause issues with actions
# ynh_abort_if_errors

#=================================================
# RETRIEVE ARGUMENTS
#=================================================

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --app=$app --key=install_dir)

#=================================================
# SPECIFIC GETTERS FOR TOML SHORT KEY
#=================================================
get__backends_urls() {
    local backends=$(grep -E '^backends\s+=\s+' "/etc/$app/server.conf" 2>/dev/null | cut -d= -f2 | sed 's/[", ]//g')
    for backend in ${backends//,/ }; do
        if [[ -n "$backend" ]]; then
            local url=$(sed -n "/\\[$backend\\]/,/\\[/p" "/etc/$app/server.conf" 2>/dev/null | \
                      grep -E -v "^(#|$|\\[)" | \
                      grep -m1 -E 'url\s+=\s+' | \
                      cut -d= -f2 | \
                      sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            if [[ -n "$url" ]]; then
                echo "$url"
            fi
        fi
    done
}

#=================================================
# SPECIFIC VALIDATORS FOR TOML SHORT KEYS
#=================================================

validate__backends_urls() {
    for url in $backends_urls; do
        if [[ ! "$url" =~ ^https?:// ]]; then
            echo "Invalid URL format: $url. Must start with http:// or https://"
            return 1
        fi
    done
}

#=================================================
# SPECIFIC SETTERS FOR TOML SHORT KEYS
#=================================================
set__backends_urls() {
    # Backend password generation
    while IFS= read -r backend_url; do
        if [[ -n "$backend_url" ]]; then
            local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
            local varname="pwd__${backend_id}"

            # Generate password if it doesn't exist
            if [[ -z "$(ynh_app_setting_get --key="$varname")" ]]; then
                local password=$(ynh_string_random --length=32)
                ynh_app_setting_set --key="$varname" --value="$password"
            fi
        fi
    done <<< "$backends_urls"

    # Export backend passwords as environment variables for Jinja template
    while IFS= read -r backend_url; do
        if [[ -n "$backend_url" ]]; then
            local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
            local varname="pwd__${backend_id}"
            local password=$(ynh_app_setting_get --key="$varname")
            export "$varname"="$password"
        fi
    done <<< "$backends_urls"

    # Update configuration
    ynh_config_add --jinja --template="server.conf" --destination="/etc/$app/server.conf"
    chmod 600 "/etc/$app/server.conf"
    chown "$app:$app" "/etc/$app/server.conf"

    # Restart the service
    ynh_systemctl --service="$app" --action=restart
}
#=================================================
# SPECIFIC ACTIONS
#=================================================
run__get_secrets() {
    echo "=== Nextcloud Signaling Configuration ==="
    echo ""
    
    # Method 1: Try to read from server.conf
    if [[ -f "/etc/$app/server.conf" ]]; then
        echo "Reading configuration from /etc/$app/server.conf"
        echo ""
        
        # Get backend IDs from the backends line
        local backends_line=$(grep -E '^backends\s*=' "/etc/$app/server.conf" 2>/dev/null | cut -d= -f2 | sed 's/[", ]//g')
        
        if [[ -n "$backends_line" ]]; then
            # Process each backend
            local backend_count=0
            for backend_id in ${backends_line//,/ }; do
                if [[ -n "$backend_id" ]]; then
                    backend_count=$((backend_count + 1))
                    echo "Backend $backend_count ID: $backend_id"
                    
                    # Extract URL and secret for this backend
                    local url=$(sed -n "/^\\[$backend_id\\]/,/^\\[/p" "/etc/$app/server.conf" | grep -E '^url\s*=' | head -1 | cut -d= -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    local secret=$(sed -n "/^\\[$backend_id\\]/,/^\\[/p" "/etc/$app/server.conf" | grep -E '^secret\s*=' | head -1 | cut -d= -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                    
                    if [[ -n "$url" && -n "$secret" ]]; then
                        echo "  URL: $url"
                        echo "  Secret: $secret"
                        echo ""
                        echo "  Add this to your Nextcloud config.php:"
                        echo "  'talk' => ["
                        echo "    'servers' => ["
                        echo "      ['server' => '$url', 'secret' => '$secret']"
                        echo "    ]"
                        echo "  ]"
                        echo ""
                        echo "----------------------------------------"
                        echo ""
                    else
                        echo "  Warning: Could not extract URL or secret for backend $backend_id"
                        echo ""
                    fi
                fi
            done
            
            if [[ $backend_count -eq 0 ]]; then
                echo "No valid backends found in configuration"
            fi
        else
            echo "No backends configured in server.conf"
        fi
    else
        echo "Configuration file not found: /etc/$app/server.conf"
    fi
    
    # Method 2: Fallback - read from YunoHost settings
    echo ""
    echo "=== Alternative: Read from YunoHost Settings ==="
    echo ""
    
    local saved_backends=$(ynh_app_setting_get --key=backends_urls 2>/dev/null)
    if [[ -n "$saved_backends" ]]; then
        echo "Saved backend URLs:"
        while IFS= read -r backend_url; do
            if [[ -n "$backend_url" ]]; then
                local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
                local varname="pwd__${backend_id}"
                local password=$(ynh_app_setting_get --key="$varname" 2>/dev/null)
                
                echo "  URL: $backend_url"
                echo "  Secret: $password"
                echo ""
                echo "  Add this to your Nextcloud config.php:"
                echo "  'talk' => ["
                echo "    'servers' => ["
                echo "      ['server' => '$backend_url', 'secret' => '$password']"
                echo "    ]"
                echo "  ]"
                echo ""
                echo "----------------------------------------"
                echo ""
            fi
        done <<< "$saved_backends"
    else
        echo "No backend URLs found in YunoHost settings"
    fi
    
    # Method 3: Instructions for manual retrieval
    echo ""
    echo "=== Manual Configuration Retrieval ==="
    echo ""
    echo "If the above methods don't work, you can manually extract the configuration:"
    echo ""
    echo "1. Check the configuration file:"
    echo "   sudo cat /etc/$app/server.conf | grep -A 5 -B 1 '\\[.*\\]'"
    echo ""
    echo "2. Check YunoHost settings:"
    echo "   yunohost app setting $app backends_urls"
    echo "   yunohost app setting $app --list | grep pwd__"
    echo ""
    echo "3. Your signaling server URL should be:"
    echo "   https://$(ynh_app_setting_get --key=domain)$(ynh_app_setting_get --key=path)/"
    echo ""
    
    return 0
}

#=================================================
ynh_app_config_run "$1"
