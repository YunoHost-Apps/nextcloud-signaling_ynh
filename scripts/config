#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

# Don't use ynh_abort_if_errors for config scripts as it can cause issues with actions
# ynh_abort_if_errors

#=================================================
# RETRIEVE ARGUMENTS
#=================================================

app=$YNH_APP_INSTANCE_NAME
install_dir=$(ynh_app_setting_get --app=$app --key=install_dir)

#=================================================
# SPECIFIC GETTERS FOR TOML SHORT KEY
#=================================================
get__backends_urls() {
    # Get backends_urls from saved settings instead of parsing config file
    local saved_backends=$(ynh_app_setting_get --key=backends_urls)
    if [[ -n "$saved_backends" ]]; then
        echo "$saved_backends"
    fi
}

get__server_url() {
    local domain=$(ynh_app_setting_get --key=domain)
    local path=$(ynh_app_setting_get --key=path)
    echo "https://$domain$path/"
}

# Removed redundant get__shared_secret function - using backend_info instead

get__backend_info() {
    local saved_backends=$(ynh_app_setting_get --key=backends_urls)
    if [[ -n "$saved_backends" ]]; then
        local result=""
        local count=1
        while IFS= read -r backend_url; do
            if [[ -n "$backend_url" ]]; then
                local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
                local password=$(ynh_app_setting_get --key="pwd__${backend_id}")
                local server_name=$(echo "$backend_url" | sed 's@https://@@' | sed 's@/.*@@')
                if [[ $count -eq 1 ]]; then
                    result="Server ${count} - ${server_name} - ${password}"
                else
                    result="${result} | Server ${count} - ${server_name} - ${password}"
                fi
                count=$((count + 1))
            fi
        done <<< "$saved_backends"
        echo "$result"
    else
        echo "No backends configured"
    fi
}

get__config_example() {
    local domain=$(ynh_app_setting_get --key=domain)
    local path=$(ynh_app_setting_get --key=path)
    local saved_backends=$(ynh_app_setting_get --key=backends_urls)

    if [[ -n "$saved_backends" ]]; then
        local backend_count=$(echo "$saved_backends" | wc -l)
        if [[ $backend_count -eq 1 ]]; then
            echo "Add to Nextcloud config.php talk servers section with the URL and secret above"
        else
            echo "Configure each Nextcloud server with the Signaling URL and its corresponding secret"
        fi
    else
        echo "Configure Backend URLs first"
    fi
}

#=================================================
# SPECIFIC VALIDATORS FOR TOML SHORT KEYS
#=================================================

validate__backends_urls() {
    for url in $backends_urls; do
        if [[ ! "$url" =~ ^https?:// ]]; then
            echo "Invalid URL format: $url. Must start with http:// or https://"
            return 1
        fi
    done
}

#=================================================
# SPECIFIC SETTERS FOR TOML SHORT KEYS
#=================================================
set__backends_urls() {
    # Save the backends_urls setting
    ynh_app_setting_set --key=backends_urls --value="$backends_urls"
    
    # Backend password generation
    while IFS= read -r backend_url; do
        if [[ -n "$backend_url" ]]; then
            local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
            local varname="pwd__${backend_id}"

            # Generate password if it doesn't exist
            if [[ -z "$(ynh_app_setting_get --key="$varname")" ]]; then
                local password=$(ynh_string_random --length=32)
                ynh_app_setting_set --key="$varname" --value="$password"
            fi
        fi
    done <<< "$backends_urls"

    # Export backend passwords as environment variables for Jinja template
    while IFS= read -r backend_url; do
        if [[ -n "$backend_url" ]]; then
            local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
            local varname="pwd__${backend_id}"
            local password=$(ynh_app_setting_get --key="$varname")
            export "$varname"="$password"
        fi
    done <<< "$backends_urls"

    # Update configuration
    ynh_config_add --jinja --template="server.conf" --destination="/etc/$app/server.conf"
    chmod 600 "/etc/$app/server.conf"
    chown "$app:$app" "/etc/$app/server.conf"

    # Restart the service
    ynh_systemctl --service="$app" --action=restart
}
#=================================================
# SPECIFIC ACTIONS
#=================================================
run__get_secrets() {
    # Simple version that just creates the file for backup access
    local output_file="/tmp/nextcloud-signaling-config.txt"
    local domain=$(ynh_app_setting_get --key=domain)
    local path=$(ynh_app_setting_get --key=path)
    local saved_backends=$(ynh_app_setting_get --key=backends_urls)

    if [[ -n "$saved_backends" ]]; then
        cat > "$output_file" << EOF
NEXTCLOUD TALK SIGNALING SERVER CONFIGURATION
==============================================

Signaling Server URL: https://$domain$path/

Backend Configurations:
EOF

        local count=1
        while IFS= read -r backend_url; do
            if [[ -n "$backend_url" ]]; then
                local backend_id=$(echo "$backend_url" | sed 's@^https://@@ ; s/[.-]/_/g ; s@/@_@g')
                local password=$(ynh_app_setting_get --key="pwd__${backend_id}")
                
                cat >> "$output_file" << EOF

Backend $count: $backend_url
Secret: $password

Add this to your Nextcloud config.php:
'talk' => [
  'servers' => [
    [
      'server' => 'https://$domain$path/',
      'secret' => '$password'
    ]
  ]
],
EOF
                count=$((count + 1))
            fi
        done <<< "$saved_backends"

        cat >> "$output_file" << EOF

Configuration saved to: $output_file
EOF
        chmod 644 "$output_file"
        echo "Configuration file created with secrets for all $((count-1)) backend(s)"
    else
        echo "No backend configuration found. Please configure backend URLs first."
    fi

    return 0
}

#=================================================
ynh_app_config_run "$1"
